# ===== Swasthya Setu — Environment Variables =====
# Copy this file to .env and fill in your keys

# --- REQUIRED for AI Chatbot ---
# Get free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- REQUIRED for Maps ---
# Get key at: https://developer.mapmyindia.com/
MAPPLS_KEY=your_mappls_key_here

# --- OPTIONAL: Voice & Translation ---
# Get key at: https://www.sarvam.ai/
SARVAM_API_KEY=your_sarvam_api_key_here

# --- OPTIONAL: Fallback STT/Translation ---
# Get key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_key_here

# --- OPTIONAL: Database ---
# Without this, app runs in demo mode with in-memory data
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/swasthyasetu

# --- OPTIONAL: Blockchain ---
ETHEREUM_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_key
WALLET_PRIVATE_KEY=your_wallet_private_key
VIAL_LEDGER_ADDRESS=your_deployed_contract_address

# --- Replit-only (auto-configured, ignore if running locally) ---
# AI_INTEGRATIONS_GEMINI_BASE_URL=
# AI_INTEGRATIONS_GEMINI_API_KEY=
